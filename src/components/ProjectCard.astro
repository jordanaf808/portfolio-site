---
import { Picture } from 'astro:assets';
import type { ProjectEntry } from '@/types';
import StatusBadge from '@/components/StatusBadge.astro';

interface Props {
  project: ProjectEntry;
  index: number;
}
const { project, index } = Astro.props;
const label = String(index + 1).padStart(3, '0');
---
<style>
  .card-header {
    --card-label-color: #888888;
  }

  .group:hover .card-header {
    /* background-color: #ede5dd; */
    background-color: #c4b8ad;
    --card-label-color: rgba(255, 255, 255, 0.65);
  }

  .card-title,
  .card-label,
  .card-meta {
    transition: color 400ms ease;
  }

  .group:hover .card-title {
    color: #ffffff;
  }

  .group:hover .card-label,
  .group:hover .card-meta {
    color: rgba(255, 255, 255, 0.65);
  }
</style>

<article class="group">
  <a href={`/projects/${project.slug}`} class="block">

    <!-- Card header -->
    <div class="card-header flex items-stretch justify-between p-6 border-b border-primary bg-surface transition-colors duration-300">
      <div>
        <h2 class="card-title font-display text-3xl text-text mb-1">{project.title}</h2>
        <p class="card-label font-mono text-xs uppercase tracking-widest text-muted">{project.subtitle}</p>
      </div>
      <div class="flex flex-col justify-between text-right shrink-0 ml-8 p-1">
        <p class="card-meta font-mono text-xs text-muted">{project.year}</p>
        <StatusBadge status={project.status} />
      </div>
    </div>

    <!-- Image -->
    <div class="relative aspect-[16/10] overflow-hidden border-b border-primary bg-surface-container-high">
      <Picture
        src={project.images[0]}
        formats={['avif', 'webp']}
        alt={project.title}
        widths={[400, 800, 1200, 1600]}
        sizes="(min-width: 1400px) calc((100vw - 500px) / 2), (min-width: 1000px) calc(100vw - 500px), 100vw"
        class="w-full h-full object-cover grayscale-hover"
        loading={index === 0 ? 'eager' : 'lazy'}
        decoding="async"
        fetchpriority={index === 0 ? 'high' : 'auto'}
      />
      <!-- Counter -->
      <div class="absolute bottom-4 right-4 bg-primary text-surface font-mono text-xs uppercase tracking-widest px-3 py-1">
        {label}
      </div>
      <!-- Tech tags -->
      <!-- <div class="absolute bottom-4 left-4 flex flex-wrap justify-end gap-0.5 max-w-[60%]">
        {project.tech.slice(0, 3).map((t) => (
          <span class="font-mono text-xs uppercase tracking-[0.05em] text-surface px-3 py-1 bg-primary">
            {t}
          </span>
        ))}
      </div> -->
      <!-- Hover overlay -->
      <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-primary/10 pointer-events-none">
        <span class="bg-primary text-surface font-mono text-xs uppercase tracking-[0.15em] px-6 py-3">
          Learn More →
        </span>
      </div>
    </div>
  </a>
</article>
