---
interface Props {
  activePage?: 'lookbook' | 'archive' | 'project';
}
const { activePage = 'lookbook' } = Astro.props;
---
<aside
  id="left-panel"
  class="fixed top-0 left-0 h-full w-[80vw] max-w-lg min-[1000px]:static min-[1000px]:w-[500px] min-[1000px]:max-w-none min-[1000px]:min-h-0 min-[1000px]:overflow-y-auto border-r border-primary bg-background flex flex-col z-40 -translate-x-full min-[1000px]:translate-x-0 transition-transform duration-300 ease-in-out"
>
  <button
    id="close-left-panel"
    class="absolute top-4 right-4 min-[1000px]:hidden font-mono text-xs uppercase tracking-widest text-muted hover:text-text transition-colors"
    aria-label="Close navigation menu"
  >
    × Close
  </button>
  <!-- Brand header -->
  <div class="border-b border-primary grid grid-cols-2">
    <!-- Title: full-width row 1 by default; col 2 / row 1 at 1300px+ -->
    <div class="col-start-1 col-span-2 row-start-1 p-6 self-start border-primary min-[1000px]:border-b min-[1000px]:min-h-37">
      <h1 class="font-display italic text-[40px] leading-[50px] text-text">
        Jordan A.F.
      </h1>
      <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted">
        Shopify & JS/TS Development
      </p>
      <div class="flex items-center gap-1.5 mt-3">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 flex-shrink-0" aria-hidden="true"></span>
        <span data-availability-label class="font-mono text-xs uppercase tracking-[0.15em] text-muted">Available Q3 2026</span>
      </div>
    </div>
    <!-- Image: col 1, row 2, portrait by default; col 1, row-span-2 at 1300px+ -->
    <div class="hidden min-[1000px]:block col-start-1 row-start-2 row-span-1 aspect-2/3 border-r border-primary">
      <img
        src="/profile-pic.jpg"
        alt="Jordan A.F."
        class="w-full h-full object-cover object-top grayscale-hover"
      />
    </div>
    <!-- About: col 2, row 2 always -->
    <div class="hidden min-[1000px]:flex col-start-2 row-start-2 p-5 pr-3.5 flex-col justify-center">
      <!-- <p class="text-base min-[1000px]:text-base/8 text-muted leading-snug ">
        Full-stack developer specialising in Shopify commerce and JS/TS engineering. I build fast, precise digital storefronts for brands that care about craft — from custom theme development to bespoke Storefront API integrations.
      </p> -->
      <p class="text-base min-[1000px]:text-[1rem] text-text leading-8 indent-3">
        I am a Shopify / JavaScript developer with over 5 years of experience building eCommerce storefronts for everyone from boutique shops to enterprise brands serving 1M+ monthly visitors, with a consistent focus on CRO-driven feature work, improving Core Web Vitals, and quality user experience.
      </p>
    </div>
  </div>

  <!-- 2×2 bento navigation grid -->
  <div class="grid grid-cols-1 grid-rows-4 flex-1 min-[1000px]:grid-cols-2 min-[1000px]:grid-rows-2">
    <a
      href="/"
      class:list={[
        'nav-cell relative flex flex-col justify-between p-5 border-b border-primary min-[1000px]:border-r',
        activePage === 'lookbook' ? 'bg-surface-container-high' : '',
      ]}
    >
      <div class="marquee-wrap" aria-hidden="true">
        <div class="marquee-track">
          <span class="marquee-text">Selected Work</span>
          <span class="marquee-text">Selected Work</span>
          <span class="marquee-text">Selected Work</span>
          <span class="marquee-text">Selected Work</span>
        </div>
      </div>
      <span class="nav-cell-label font-mono text-xs uppercase tracking-[0.1em] text-muted relative z-10">Portfolio</span>
      <span class="nav-cell-title font-display text-lg text-text relative z-10">Selected Work</span>
    </a>
    <a
      href="/archive"
      class:list={[
        'nav-cell relative flex flex-col justify-between p-5 border-b border-primary',
        activePage === 'archive' ? 'bg-surface-container-high' : '',
      ]}
    >
      <div class="marquee-wrap" aria-hidden="true">
        <div class="marquee-track">
          <span class="marquee-text">All Projects</span>
          <span class="marquee-text">All Projects</span>
          <span class="marquee-text">All Projects</span>
          <span class="marquee-text">All Projects</span>
        </div>
      </div>
      <span class="nav-cell-label font-mono text-xs uppercase tracking-[0.1em] text-muted relative z-10">Archive</span>
      <span class="nav-cell-title font-display text-lg text-text relative z-10">All Projects</span>
    </a>
    <a
      href="/#services"
      class="nav-cell relative flex flex-col justify-between p-5 border-b border-primary min-[1000px]:border-b-0 min-[1000px]:border-r"
    >
      <div class="marquee-wrap" aria-hidden="true">
        <div class="marquee-track">
          <span class="marquee-text">What I Do</span>
          <span class="marquee-text">What I Do</span>
          <span class="marquee-text">What I Do</span>
          <span class="marquee-text">What I Do</span>
        </div>
      </div>
      <span class="nav-cell-label font-mono text-xs uppercase tracking-[0.1em] text-muted relative z-10">Services</span>
      <span class="nav-cell-title font-display text-lg text-text relative z-10">What I Do</span>
    </a>
    <button
      id="open-cart-drawer-left"
      class="nav-cell relative flex flex-col justify-between p-5 text-left w-full"
    >
      <div class="marquee-wrap" aria-hidden="true">
        <div class="marquee-track">
          <span class="marquee-text">Get In Touch</span>
          <span class="marquee-text">Get In Touch</span>
          <span class="marquee-text">Get In Touch</span>
          <span class="marquee-text">Get In Touch</span>
        </div>
      </div>
      <span class="nav-cell-label font-mono text-xs uppercase tracking-[0.1em] text-muted relative z-10">Contact</span>
      <span class="nav-cell-title font-display text-lg text-text relative z-10">Get In Touch</span>
    </button>
  </div>

  <!-- Tech tags -->
  <div class="p-8 border-t border-primary">
    <div class="flex flex-wrap gap-2">
      {['Shopify Plus', 'Liquid', 'JS', 'TypeScript', 'React', 'Next'].map((tag) => (
        <span class="font-mono text-xs uppercase tracking-[0.1em] border border-primary px-2 py-1 text-muted">
          {tag}
        </span>
      ))}
    </div>
  </div>

</aside>

<script>
  import { getCurrentQuarterLabel } from '@/utils/date';

  document.getElementById('open-cart-drawer-left')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-cart-drawer'));
  });

  const label = `Available ${getCurrentQuarterLabel()}`;
  document.querySelectorAll<HTMLElement>('[data-availability-label]').forEach((el) => {
    el.textContent = label;
  });
</script>

<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .nav-cell {
    position: relative;
    outline: none;
    transition: background-color 400ms ease;
  }

  .nav-cell:hover,
  .nav-cell:focus-visible {
    /* background-color: #C8B6A6; */
    /* background-color: color-mix(in oklab, var(--color-accent-taupe) 30%, transparent); */
    background-color: #c8b6a66e;
  }

  .marquee-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 400ms ease;
  }

  .nav-cell:hover .marquee-wrap,
  .nav-cell:focus-visible .marquee-wrap {
    opacity: 1;
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    animation: marquee-scroll 9s linear infinite;
  }

  .marquee-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 96px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.35);
    padding-right: 48px;
    user-select: none;
  }

  .nav-cell-label {
    transition: color 400ms ease;
  }

  .nav-cell:hover .nav-cell-label,
  .nav-cell:focus-visible .nav-cell-label {
    color: rgba(255, 255, 255, 0.65);
  }

  .nav-cell-title {
    transition: color 400ms ease;
  }

  .nav-cell:hover .nav-cell-title,
  .nav-cell:focus-visible .nav-cell-title {
    color: #ffffff;
  }
</style>
