---
import type { TechBadge } from '../data/services.ts'

interface Props {
  badge: TechBadge
}
const { badge } = Astro.props
---

<div class="flex flex-col items-center gap-3 py-6 px-4 border-b border-primary bg-surface transition-colors duration-300 hover:bg-surface-container-high">
  <img
    src={badge.src}
    alt={badge.name}
    class="w-[72px] h-[72px]"
    style="image-rendering: pixelated;"
    loading="lazy"
    decoding="async"
  />
  <span class="font-mono text-[11px] uppercase tracking-[0.1em] text-muted">
    {badge.name}
  </span>
</div>

<style>
  div:not(:nth-child(3n)) {
    border-right: 1px solid var(--color-primary);
  }
</style>
