---
interface Props {
  tag: string;
  // Three call sites render the badge with intentionally different weights:
  // panel = LeftPanel footer, hero = project detail hero, table = archive row.
  variant?: 'panel' | 'hero' | 'table';
}
const { tag, variant = 'panel' } = Astro.props;
const variants: Record<NonNullable<Props['variant']>, string> = {
  panel: 'tracking-[0.1em] border-primary px-2 py-1 text-muted',
  hero: 'tracking-[0.1em] border-primary px-3 py-1 text-text',
  table: 'tracking-[0.05em] border-muted/40 px-1.5 py-0.5 text-muted',
};
---
<span class:list={['font-mono text-xs uppercase border', variants[variant]]}>{tag}</span>
