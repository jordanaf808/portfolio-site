---
import { Picture } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import AvailabilityBadge from '@/components/AvailabilityBadge.astro';
import { getFeaturedProjects } from '@/data/projects.ts';
import { getFeaturedJobRoles } from '@/data/jobRoles.ts';
import profilePic from '@/assets/profile-pic.jpg';

const projects = [...getFeaturedProjects(), ...getFeaturedJobRoles()];
---
<style>
  @media (min-width: 1400px) {
    .project-grid {
      column-gap: 1px;
      background-color: var(--color-primary);
    }
  }
</style>

<Layout
  title="Jordan A.F. — Shopify & JS/TS Developer"
  description="Jordan A.F. — Shopify Plus & JS/TS developer based in L.A. 5+ years building eCommerce storefronts for boutique-to-enterprise brands; featured work and selected projects."
  activePage="lookbook"
>
  <!-- Brand header -->
  <div class="border-b border-primary grid grid-cols-1 min-[540px]:grid-cols-2 min-[1000px]:hidden">
    <!-- Title: stacked row 1 below 540px; col 2 / row 1 at 540px+ -->
    <div class="flex flex-col items-center p-8 self-start border-b border-primary min-[540px]:col-start-2 min-[540px]:col-span-1 min-[540px]:row-start-1">
      <h1 class="font-display italic text-[40px] leading-12.5 text-text w-full min-[670px]:max-w-76">
        Jordan A.F.
      </h1>
      <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted mt-1 w-full min-[670px]:max-w-76">
        Shopify & JS/TS Development
      </p>
      <AvailabilityBadge class="mt-2 w-full min-[670px]:max-w-76" />
    </div>

    <!-- Image: stacked row 2 below 540px; col 1, row-span-2 at 540px+ -->
    <div class="max-[540px]:max-h-138 min-[640px]:max-h-154 border-b border-primary min-[540px]:col-start-1 min-[540px]:row-start-1 min-[540px]:row-span-2 min-[540px]:aspect-auto min-[540px]:border-r min-[540px]:border-b-0">
      <Picture
        src={profilePic}
        formats={['avif', 'webp']}
        alt="Jordan's profile image"
        widths={[400, 800]}
        sizes="(min-width: 540px) 50vw, 100vw"
        class="w-full h-full object-cover object-top grayscale-hover"
      />
    </div>
    <!-- About: stacked row 3 below 540px; col 2, row 2 at 540px+ -->
    <div class="w-full p-8 py-6 flex flex-col items-center indent-8 ">
      <!-- <p class="text-lg/10 text-muted leading-relaxed">
        Full-stack developer specialising in Shopify commerce and JS/TS engineering. I build fast, precise digital storefronts for brands that care about craft — from custom theme development to bespoke Storefront API integrations.
      </p> -->
      <p class="min-[670px]:max-w-75 md:text-lg text-text font-mono text-justify leading-9">
        I am a Shopify / JavaScript developer with 5+ years of experience building eCommerce storefronts for everyone from boutique shops to enterprise brands serving 1M+ monthly visitors. I focus on CRO-driven feature work, improving Core Web Vitals, and building a quality user experience.
      </p>
      <!-- <p class="text-lg text-muted leading-8">
        I've shipped 40+ Shopify and WordPress sites at a boutique agency, kept SimpleHuman's 13-country storefront humming as their in-house dev, and built A/B tested features at True Classic, like lazy-loaded multi-collection product grids and Metaobject-driven multi-level navigation. Whether running solo or shoulder-to-shoulder with a bigger team, I bring clean code, clear communication, and work I'd be proud to put my name on. When I'm not coding, I'm usually on a bike, off-road getting dirty, or making too much noise with a guitar.
      </p> -->
    </div>
  </div>

  <!-- Project feed -->
  <div>
    <!-- Section header -->
    <div class="p-6 border-b border-primary min-[1000px]:min-h-37 flex items-center">
      <h2 class="w-full font-display text-[36px] text-center min-[540px]:text-5xl min-[1000px]:text-left italic text-text translate-y-0.5">Selected Work</h2>
      <!-- <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-2">
        2023–2024
      </p> -->
    </div>
    <div class="project-grid grid grid-cols-1 min-[1400px]:grid-cols-2">
      {projects.map((project, i) => {
        if (project.featured) return (
        <ProjectCard project={project} index={i} />)
      })}
    </div>
  </div>

  <footer class="p-6 min-h-[95px] min-[600px]:min-h-[63px] flex items-center">
    <p class="font-mono text-xs text-muted">© {new Date().getFullYear()} JordanAF-Dev</p>
  </footer>
</Layout>
