---
import type { BaseEntry } from '@/types';

interface Props {
  status: BaseEntry['status'];
}
const { status } = Astro.props;
const dotColor: Record<BaseEntry['status'], string> = {
  COMPLETE: 'bg-green-500',
  ACTIVE: 'bg-yellow-400',
  ARCHIVED: 'bg-gray-400',
};
---
<style>
  .status-label {
    color: var(--card-label-color, #888888);
    transition: color 400ms ease;
  }
</style>

<span class="flex justify-end items-center gap-2.5">
  <p class="status-label font-mono text-xs uppercase tracking-widest">{status}</p>
  <div class:list={['w-2 h-2 rounded-none shrink-0', dotColor[status] ?? 'bg-gray-400']}></div>
</span>
