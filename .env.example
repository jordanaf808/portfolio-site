# Server-only secret (astro:env context: 'server', access: 'secret').
# Read in src/pages/api/contact.ts via `import { RESEND_API_KEY } from 'astro:env/server'`.
# Local dev: copy this file to .env.local and paste a real key (gitignored).
# Production: set in the Cloudflare Pages dashboard (Settings -> Environment Variables).
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile — bot protection on the contact form.
# PUBLIC_ = intentionally public site key (rendered in the browser by CartDrawer.tsx).
# The secret is server-only and used by src/pages/api/contact.ts to call siteverify.
# Local dev: paste real keys here in .env.local, OR use Cloudflare's always-pass test pair
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
# Production: set both in the Cloudflare Pages dashboard (Settings -> Environment Variables).
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_SITE_KEY=0x4xxxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
