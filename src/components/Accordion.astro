---
import { parseParagraphs } from '../lib/parseParagraphs.ts'
interface Props {
  title: string
  open?: boolean
  content?: string | string[]
  convertSingleNewlineToBr?: boolean
}
const { title, open = false, content, convertSingleNewlineToBr = true } = Astro.props
const paragraphsLines = parseParagraphs(content).map((p) => p.split('\n'))
---

<div class="border-b border-primary" data-accordion>
  <button
    class="group flex items-center justify-between w-full p-6 text-left cursor-pointer hover:bg-surface-container-low transition-colors duration-300"
    aria-expanded={open ? 'true' : 'false'}
    data-accordion-trigger
  >
    <span class="font-mono text-xs uppercase tracking-[0.15em] text-text">{title}</span>
    <span
      class="font-mono text-xl leading-none text-muted transition-transform duration-300 inline-block group-aria-expanded:rotate-45"
      aria-hidden="true"
    >+</span>
  </button>
  <div
    class="grid transition-[grid-template-rows] duration-300 ease-in-out"
    style={`grid-template-rows: ${open ? '1fr' : '0fr'}`}
    data-accordion-content
  >
    <div class="overflow-hidden">
      <div class="px-6 pb-6 text-sm text-muted leading-relaxed max-w-prose mx-auto">
        {content ? (
          paragraphsLines.map((lines) => (
              lines.map((line, i) => (
                <p class="mb-6 last:mb-0">
                  {line}{convertSingleNewlineToBr && i < lines.length - 1 ? <br /> : null}
                </p>
              ))
          ))
        ) : (
          <slot />
        )}
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-accordion]').forEach((accordion) => {
    const trigger = accordion.querySelector<HTMLButtonElement>('[data-accordion-trigger]')
    const content = accordion.querySelector<HTMLElement>('[data-accordion-content]')
    if (!trigger || !content) return

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true'
      trigger.setAttribute('aria-expanded', String(!isOpen))
      content.style.gridTemplateRows = isOpen ? '0fr' : '1fr'
    })
  })
</script>
