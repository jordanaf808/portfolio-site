---
interface Props {
  images: string[];
  title: string;
}
const { images, title } = Astro.props;
const total = images.length;
---
<div class="sticky top-0 h-[calc(100vh-3rem)] flex flex-col border-r border-primary">
  <!-- Main image area -->
  <div class="relative flex-1 overflow-hidden bg-surface-container-high">
    {images.map((src, i) => (
      <img
        id={`gallery-img-${i}`}
        src={src}
        alt={`${title} — image ${i + 1}`}
        class:list={[
          'w-full h-full object-cover grayscale-hover absolute inset-0 transition-opacity duration-500',
          i === 0 ? 'opacity-100' : 'opacity-0',
        ]}
        loading={i === 0 ? 'eager' : 'lazy'}
        onerror="this.parentElement.style.background='#EFEFEB'"
      />
    ))}
    <!-- Counter badge -->
    <div id="gallery-counter" class="absolute bottom-4 right-4 bg-primary text-surface font-mono text-xs px-3 py-1">
      01 / {String(total).padStart(2, '0')}
    </div>
  </div>

  <!-- Prev / Next controls -->
  <div class="grid grid-cols-3 h-12 border-t border-primary flex-shrink-0">
    <button id="gallery-prev" class="flex items-center justify-center border-r border-primary hover:bg-surface-container-high transition-colors font-mono text-sm">
      ←
    </button>
    <div class="flex items-center justify-center font-mono text-xs uppercase tracking-[0.1em] text-muted">
      Prev / Next
    </div>
    <button id="gallery-next" class="flex items-center justify-center border-l border-primary hover:bg-surface-container-high transition-colors font-mono text-sm">
      →
    </button>
  </div>
</div>

<script is:inline define:vars={{ total }}>
  let current = 0;

  function showImage(index) {
    document.querySelectorAll('[id^="gallery-img-"]').forEach((img, i) => {
      img.style.opacity = i === index ? '1' : '0';
    });
    const counter = document.getElementById('gallery-counter');
    if (counter) {
      counter.textContent =
        String(index + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
    }
  }

  document.getElementById('gallery-prev')?.addEventListener('click', () => {
    current = (current - 1 + total) % total;
    showImage(current);
  });

  document.getElementById('gallery-next')?.addEventListener('click', () => {
    current = (current + 1) % total;
    showImage(current);
  });
</script>
