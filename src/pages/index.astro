---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getFeaturedProjects } from '../data/projects.ts';
import { getFeaturedJobRoles } from '../data/jobRoles.ts';

const projects = [...getFeaturedProjects(), ...getFeaturedJobRoles()];
---
<style>
  @media (min-width: 1400px) {
    .project-grid {
      column-gap: 1px;
      background-color: var(--color-primary);
    }
  }
</style>

<Layout title="Lookbook" activePage="lookbook">
  <!-- Brand header -->
  <div class="border-b border-primary grid grid-cols-1 min-[540px]:grid-cols-2 min-[1000px]:hidden">
    <!-- Title: stacked row 1 below 540px; col 2 / row 1 at 540px+ -->
    <div class="p-6 self-start border-b border-primary min-[540px]:col-start-2 min-[540px]:col-span-1 min-[540px]:row-start-1">
      <h1 class="font-display italic text-3xl leading-tight text-text">
        Jordan A.F.
      </h1>
      <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted mt-1">
        Shopify & JS/TS Development
      </p>
    </div>
    <!-- Image: stacked row 2 below 540px; col 1, row-span-2 at 540px+ -->
    <div class="h-72 border-b border-primary min-[540px]:h-auto min-[540px]:col-start-1 min-[540px]:row-start-1 min-[540px]:row-span-2 min-[540px]:aspect-auto min-[540px]:border-r min-[540px]:border-b-0">
      <img
        src="/profile-pic.jpg"
        alt="Jordan A.F."
        class="w-full h-full object-cover object-top grayscale-hover"
      />
    </div>
    <!-- About: stacked row 3 below 540px; col 2, row 2 at 540px+ -->
    <div class="p-6 pr-5.5 flex flex-col justify-start indent-8 min-[540px]:col-start-2 min-[540px]:row-start-2">
      <!-- <p class="text-lg/10 text-muted leading-relaxed">
        Full-stack developer specialising in Shopify commerce and JS/TS engineering. I build fast, precise digital storefronts for brands that care about craft — from custom theme development to bespoke Storefront API integrations.
      </p> -->
      <p class="text-lg text-muted leading-8">
        I'm a Shopify and JavaScript developer based in L.A. For the past 5+ years I've been building e-commerce storefronts for everyone from boutique shops to enterprise brands serving 1M+ monthly visitors, with a consistent focus on CRO-driven feature work, improving Core Web Vitals, and quality user experience.
      </p>
      <p class="text-lg text-muted leading-8">
        I've shipped 40+ Shopify and WordPress sites at a boutique agency, kept SimpleHuman's 13-country storefront humming as their in-house dev, and built A/B tested features at True Classic, like lazy-loaded multi-collection product grids and Metaobject-driven multi-level navigation. Whether running solo or shoulder-to-shoulder with a bigger team, I bring clean code, clear communication, and work I'd be proud to put my name on. When I'm not coding, I'm usually on a bike, off-road getting dirty, or making too much noise with a guitar.
      </p>
    </div>
  </div>

  <!-- Project feed -->
  <div>
    <!-- Section header -->
    <div class="p-7 border-b border-primary min-[1000px]:min-h-27">
      <h2 class="font-display text-4xl/10 text-center min-[540px]:text-5xl min-[1000px]:text-left italic text-text">Selected Work</h2>
      <!-- <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-2">
        2023–2024
      </p> -->
    </div>
    <div class="project-grid grid grid-cols-1 min-[1400px]:grid-cols-2">
      {projects.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>
  </div>

  <footer class="p-6">
    <p class="font-mono text-xs text-muted">© {new Date().getFullYear()} The Commerce Boutique</p>
  </footer>
</Layout>
