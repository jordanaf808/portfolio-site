---
interface Props {
  activePage?: 'lookbook' | 'archive' | 'project';
}
const { activePage = 'lookbook' } = Astro.props;
---
<aside
  id="left-panel"
  class="fixed top-0 left-0 h-full w-[80vw] min-[1000px]:w-[40%] border-r border-primary bg-background flex flex-col z-40 -translate-x-full min-[1000px]:translate-x-0 transition-transform duration-300 ease-in-out"
>
  <button
    id="close-left-panel"
    class="absolute top-4 right-4 min-[1000px]:hidden font-mono text-xs uppercase tracking-widest text-muted hover:text-text transition-colors"
    aria-label="Close navigation menu"
  >
    × Close
  </button>
  <!-- Brand header -->
  <div class="border-b border-primary grid grid-cols-2">
    <!-- Title: full-width row 1 by default; col 2 / row 1 at 1300px+ -->
    <div class="col-start-1 col-span-2 row-start-1 p-6 self-start border-primary min-[1000px]:border-b min-[1300px]:col-start-2 min-[1300px]:col-span-1">
      <h1 class="font-display italic text-3xl leading-tight text-text">
        Jordan A.F.
      </h1>
      <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted mt-1">
        Shopify & JS/TS Development
      </p>
    </div>
    <!-- Image: col 1, row 2, portrait by default; col 1, row-span-2 at 1300px+ -->
    <div class="hidden min-[1000px]:block col-start-1 row-start-2 row-span-1 aspect-2/3 border-r border-primary min-[1300px]:row-start-1 min-[1300px]:row-span-2 min-[1300px]:aspect-auto">
      <img
        src="/profile-pic.jpg"
        alt="Jordan A.F."
        class="w-full h-full object-cover object-top grayscale-hover"
      />
    </div>
    <!-- About: col 2, row 2 always -->
    <div class="hidden min-[1000px]:flex col-start-2 row-start-2 p-6 flex-col justify-center">
      <p class="text-sm text-muted leading-relaxed">
        Full-stack developer specialising in Shopify commerce and JS/TS engineering. I build fast, precise digital storefronts for brands that care about craft — from custom theme development to bespoke Storefront API integrations.
      </p>
    </div>
  </div>

  <!-- 2×2 bento navigation grid -->
  <div class="grid grid-cols-1 grid-rows-4 flex-1 min-[1000px]:grid-cols-2 min-[1000px]:grid-rows-2">
    <a
      href="/"
      class:list={[
        'group flex flex-col justify-between p-5 border-b border-primary min-[1000px]:border-r transition-colors duration-300',
        activePage === 'lookbook' ? 'bg-surface-container-high' : 'hover:bg-surface-container-high',
      ]}
    >
      <span class="font-mono text-xs uppercase tracking-[0.1em] text-muted">Portfolio</span>
      <span class="font-display text-lg text-text">Selected Work</span>
    </a>
    <a
      href="/archive"
      class:list={[
        'group flex flex-col justify-between p-5 border-b border-primary transition-colors duration-300',
        activePage === 'archive' ? 'bg-surface-container-high' : 'hover:bg-surface-container-high',
      ]}
    >
      <span class="font-mono text-xs uppercase tracking-[0.1em] text-muted">Archive</span>
      <span class="font-display text-lg text-text">All Projects</span>
    </a>
    <a
      href="/#services"
      class="group flex flex-col justify-between p-5 border-b border-primary min-[1000px]:border-b-0 min-[1000px]:border-r transition-colors duration-300 hover:bg-surface-container-high"
    >
      <span class="font-mono text-xs uppercase tracking-[0.1em] text-muted">Services</span>
      <span class="font-display text-lg text-text">What We Build</span>
    </a>
    <button
      id="open-cart-drawer-left"
      class="group flex flex-col justify-between p-5 transition-colors duration-300 hover:bg-surface-container-high text-left w-full"
    >
      <span class="font-mono text-xs uppercase tracking-[0.1em] text-muted">Contact</span>
      <span class="font-display text-lg text-text">Start a Project</span>
    </button>
  </div>

  <!-- Tech tags -->
  <div class="p-8 border-t border-primary">
    <div class="flex flex-wrap gap-2">
      {['TypeScript', 'React', 'Liquid', 'Shopify'].map((tag) => (
        <span class="font-mono text-xs uppercase tracking-[0.1em] border border-primary px-2 py-1 text-muted">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Availability footer -->
  <div class="p-6 border-t border-primary flex items-center gap-2">
    <div class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></div>
    <span class="font-mono text-xs text-muted uppercase tracking-[0.1em]">Available Q3 2026</span>
  </div>
</aside>

<script>
  document.getElementById('open-cart-drawer-left')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-cart-drawer'));
  });
</script>
