---
import { Picture, getImage } from 'astro:assets';

interface Props {
  images: ImageMetadata[];
  title: string;
}
const { images, title } = Astro.props;
const total = images.length;

// The fullscreen slideshow swaps img.src/srcset from client JS. Pre-generate both a
// 1× (1600px) and 2× (3200px) WebP per image so the browser picks by DPR.
const [sources1x, sources2x] = await Promise.all([
  Promise.all(images.map((image) => getImage({ src: image, format: 'webp', width: 1600, quality: 'max' }))),
  Promise.all(images.map((image) => getImage({ src: image, format: 'webp', width: 3200, quality: 'max' }))),
]);
const slideshowUrls = sources1x.map((s, i) => ({
  src: s.src,
  srcset: `${s.src} 1x, ${sources2x[i].src} 2x`,
}));
---
<!-- Horizontally scrolling thumbnail strip -->
<div
  id="image-gallery"
  data-images={JSON.stringify(slideshowUrls)}
  class="flex overflow-x-auto border-b border-primary"
>
  {images.map((image, i) => (
    <button
      type="button"
      data-gallery-index={i}
      class="shrink-0 w-56.25 h-70.75 overflow-hidden border-r border-primary bg-surface-container-high cursor-pointer p-0"
      aria-label={`${title} — open image ${i + 1} in slideshow`}
    >
      <Picture
        src={image}
        formats={['avif', 'webp']}
        alt={`${title} ${i + 1}`}
        widths={[450, 1000]}
        sizes="225px"
        class="w-full h-full object-cover grayscale-hover"
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    </button>
  ))}
</div>

<!-- Fullscreen slideshow -->
{total > 0 && (
  <dialog
    id="slideshow-modal"
    class="fixed inset-0 w-screen h-screen max-w-none max-h-none m-0 p-0 bg-black/90 backdrop:bg-transparent"
    aria-label="Image slideshow"
  >
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between p-6 border-b border-white/10">
        <span id="slideshow-counter" class="font-mono text-xs uppercase tracking-widest text-white/50"></span>
        <button
          id="slideshow-close"
          class="font-mono text-xs uppercase tracking-widest text-white/50 hover:text-white transition-colors"
          aria-label="Close slideshow"
        >Close ×</button>
      </div>
      <div class="flex-1 flex items-center justify-between px-6 gap-6 overflow-hidden">
        <button
          id="slideshow-prev"
          class="shrink-0 cursor-pointer font-mono text-xs uppercase tracking-widest text-white/50 hover:text-white transition-colors"
          aria-label="Previous image"
        >← Prev</button>
        <div class="flex-1 flex items-center justify-center h-full overflow-hidden">
          <img id="slideshow-img" src="" alt="" class="max-w-full max-h-full object-contain" />
        </div>
        <button
          id="slideshow-next"
          class="shrink-0 cursor-pointer font-mono text-xs uppercase tracking-widest text-white/50 hover:text-white transition-colors"
          aria-label="Next image"
        >Next →</button>
      </div>
    </div>
  </dialog>
)}

<script>
  interface SlideshowEntry { src: string; srcset: string }
  const gallery = document.getElementById('image-gallery')
  const images: SlideshowEntry[] = gallery ? JSON.parse(gallery.dataset.images ?? '[]') : []
  const modal = document.getElementById('slideshow-modal') as HTMLDialogElement | null

  if (modal && images.length > 0) {
    let current = 0
    const img = document.getElementById('slideshow-img') as HTMLImageElement
    const counter = document.getElementById('slideshow-counter')

    function showSlide(index: number): void {
      current = (index + images.length) % images.length
      img.src = images[current].src
      img.srcset = images[current].srcset
      img.alt = `Image ${current + 1} of ${images.length}`
      if (counter) {
        counter.textContent = `${String(current + 1).padStart(2, '0')} / ${String(images.length).padStart(2, '0')}`
      }
    }

    gallery?.querySelectorAll<HTMLElement>('button[data-gallery-index]').forEach((btn) => {
      btn.addEventListener('click', () => {
        showSlide(Number(btn.dataset.galleryIndex))
        modal.showModal()
      })
    })

    document.getElementById('slideshow-close')?.addEventListener('click', () => modal.close())
    document.getElementById('slideshow-prev')?.addEventListener('click', () => showSlide(current - 1))
    document.getElementById('slideshow-next')?.addEventListener('click', () => showSlide(current + 1))

    modal.addEventListener('click', (e) => {
      const t = e.target as HTMLElement
      if (t.closest('button') || t.id === 'slideshow-img') return
      modal.close()
    })

    document.addEventListener('keydown', (e) => {
      if (!modal.open) return
      if (e.key === 'ArrowLeft') showSlide(current - 1)
      if (e.key === 'ArrowRight') showSlide(current + 1)
    })
  }
</script>
