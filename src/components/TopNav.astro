---
import ContactButton from '@/components/ContactButton.astro'

interface Props {
  showHamburger?: boolean
}
const { showHamburger = false } = Astro.props
---
<nav class="flex items-center justify-between border-b border-primary h-12 px-6 bg-surface fixed top-0 left-0 right-0 z-20">
  <div class="flex items-center gap-6">
    {showHamburger && (
      <button
        id="hamburger-btn"
        class="min-[1000px]:hidden font-mono text-xs uppercase tracking-widest text-muted hover:text-text transition-colors cursor-pointer"
        aria-label="Open navigation menu"
        aria-expanded="false"
      >
        Menu
      </button>
    )}
  </div>
  <div class="flex items-center gap-3">
    <ContactButton label="Contact Me" size="sm" />
  </div>
</nav>
