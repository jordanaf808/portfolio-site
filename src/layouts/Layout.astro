---
import '../styles/global.css';
import LeftPanel from '../components/LeftPanel.astro';
import TopNav from '../components/TopNav.astro';
import CartDrawer from '../components/CartDrawer';

interface Props {
  title: string;
  activePage?: 'lookbook' | 'archive' | 'project';
}
const { title, activePage } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — The Commerce Boutique</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=Work+Sans:wght@400;500&family=Space+Grotesk:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body class="flex h-screen overflow-hidden bg-background min-[1000px]:grid min-[1000px]:grid-cols-[480px_1fr] min-[1000px]:grid-rows-[1fr]">
  <LeftPanel activePage={activePage} />

  <!-- Mobile backdrop -->
  <div
    id="left-panel-backdrop"
    class="fixed inset-0 bg-black/40 z-30 hidden"
    aria-hidden="true"
  ></div>

  <!-- Right panel: full-width on mobile, grid column 1fr on desktop -->
  <div class="w-full flex flex-col h-full min-h-0 hard-shadow-canvas">
    <div class="min-[1000px]:hidden">
      <TopNav showHamburger />
    </div>
    <main class="flex-1 overflow-y-auto bg-surface">
      <slot />
    </main>
  </div>

  <CartDrawer client:load />

  <script>
    // Mobile nav drawer
    const panel = document.getElementById('left-panel')
    const backdrop = document.getElementById('left-panel-backdrop')
    const closeBtn = document.getElementById('close-left-panel')
    const hamburger = document.getElementById('hamburger-btn')

    function openPanel(): void {
      panel?.classList.remove('-translate-x-full')
      backdrop?.classList.remove('hidden')
      document.body.style.overflow = 'hidden'
      hamburger?.setAttribute('aria-expanded', 'true')
    }

    function closePanel(): void {
      panel?.classList.add('-translate-x-full')
      backdrop?.classList.add('hidden')
      document.body.style.overflow = ''
      hamburger?.setAttribute('aria-expanded', 'false')
    }

    hamburger?.addEventListener('click', openPanel)
    closeBtn?.addEventListener('click', closePanel)
    backdrop?.addEventListener('click', closePanel)

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closePanel()
    })
  </script>
</body>
</html>
