---
import Layout from '@/layouts/Layout.astro';
import Accordion from '@/components/Accordion.astro';
import ImageGallery from '@/components/ImageGallery.astro';
import TechBadge from '@/components/TechLabel.astro';
import ContactButton from '@/components/ContactButton.astro';
import EntryNavLink from '@/components/EntryNavLink.astro';
import { projects } from '@/data/projects.ts';
import { jobRoles } from '@/data/jobRoles.ts';
import type { ProjectEntry } from '@/types';

export function getStaticPaths() {
  const all = [...projects, ...jobRoles];
  return all.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prevEntry: all.at(i - 1) as ProjectEntry,
      nextEntry: all[(i + 1) % all.length] as ProjectEntry,
    },
  }));
}

interface Props {
  entry: ProjectEntry;
  prevEntry: ProjectEntry;
  nextEntry: ProjectEntry;
}

const { entry, prevEntry, nextEntry } = Astro.props;
const description = Array.isArray(entry.description) ? entry.description[0] : entry.description;
---
<Layout
  title={`${entry.title} — Jordan A.F. | Shopify & JS/TS Developer`}
  description={description}
  ogImage={entry.images?.[0]?.src}
  activePage="project"
>
  <!-- Hero -->
  <div class="px-6 py-10 md:py-12 border-b border-primary">
    <h1 class="font-display text-5xl leading-none text-text mb-6 max-w-125">{entry.title}</h1>
    {entry.type === 'project' && (
      <p class="text-sm text-muted leading-relaxed">{description}</p>
    )}
    <div class="flex flex-wrap gap-2 max-w-125">
      {entry.tech.map((t) => <TechBadge tag={t} variant="hero" />)}
    </div>
  </div>

  <!-- Gallery: image cycler with thumbnail navigation -->
  {entry.images.length > 0 && (
    <ImageGallery images={entry.images} title={entry.title} />
  )}

  <!-- Accordions -->
  <div class="border-t border-primary">
    {entry.type === 'project' ? (
      <Fragment>
        <Accordion title="The Challenge" open content={entry.challenge} />
        <Accordion title="The Architecture" content={entry.architecture} />
        <Accordion title="The Results" content={entry.results} />
      </Fragment>
    ) : (
      <Fragment>
        <Accordion title="Overview" open content={entry.description} />
        {entry.responsibilities && (
          <Accordion title="Responsibilities" content={entry.responsibilities} />
        )}
        {entry.technologies && (
          <Accordion title="Technologies" content={entry.technologies} />
        )}
      </Fragment>
    )}
  </div>

  <!-- CTA -->
  <div class="border-t border-primary p-12">
    {entry.type === 'project' ? (
      <div class="grid grid-cols-2 gap-8 items-start">
        <ContactButton label="Get In Touch" />
        <div class="border border-primary">
          <div class="p-4 border-b border-primary">
            <p class="font-mono text-xs uppercase tracking-[0.1em] text-muted">Technical Architecture</p>
          </div>
          <div class="divide-y divide-primary">
            {[
              ['Frontend', entry.tech[0] ?? '—'],
              ['Commerce', entry.tech[1] ?? '—'],
              ['Animation', entry.tech[2] ?? '—'],
              ['Infra', 'Cloudflare Pages'],
            ].map(([key, val]) => (
              <div class="flex justify-between px-4 py-2">
                <span class="font-mono text-xs uppercase tracking-[0.05em] text-muted">{key}</span>
                <span class="font-mono text-xs text-text">{val}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    ) : (
      <ContactButton label="Contact Me →" />
    )}
  </div>

  <!-- Footer nav -->
  <div class="p-6 flex items-center justify-between border-t border-primary">
    <EntryNavLink entry={prevEntry} direction="prev" />
    <EntryNavLink entry={nextEntry} direction="next" />
  </div>
</Layout>
