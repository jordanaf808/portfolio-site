---
import { Picture } from 'astro:assets';
import AvailabilityBadge from '@/components/AvailabilityBadge.astro';
import TechBadge from '@/components/TechLabel.astro';
import profilePic from '@/assets/profile-pic.jpg';

interface Props {
  activePage?: 'lookbook' | 'archive' | 'project' | 'services';
}
const { activePage = 'lookbook' } = Astro.props;

const TECH_TAGS = ['Shopify Plus', 'Liquid', 'JS', 'TypeScript', 'React', 'Next'];

// The 2×2 bento nav. Three cells link out; the last opens the contact drawer.
// Per-cell border classes differ, so they're carried explicitly to preserve layout.
interface NavCell {
  tag: 'a' | 'button';
  attrs: Record<string, string | boolean>;
  base: string;
  active: boolean;
  label: string;
  title: string;
}
const navCells: NavCell[] = [
  {
    tag: 'a',
    attrs: { href: '/' },
    base: 'border-b border-primary min-[1000px]:border-r',
    active: activePage === 'lookbook',
    label: 'Portfolio',
    title: 'Selected Work',
  },
  {
    tag: 'a',
    attrs: { href: '/archive' },
    base: 'border-b border-primary',
    active: activePage === 'archive',
    label: 'Archive',
    title: 'All Projects',
  },
  {
    tag: 'a',
    attrs: { href: '/services' },
    base: 'border-b border-primary min-[1000px]:border-b-0 min-[1000px]:border-r',
    active: false,
    label: 'Services',
    title: 'What I Do',
  },
  {
    tag: 'button',
    attrs: { type: 'button', 'data-open-cart': true },
    base: 'text-left w-full',
    active: false,
    label: 'Contact',
    title: 'Get In Touch',
  },
];
---
<aside
  id="left-panel"
  class="fixed top-0 left-0 h-full w-[80vw] max-w-lg min-[1000px]:sticky min-[1000px]:top-0 min-[1000px]:h-screen min-[1000px]:w-[500px] min-[1000px]:max-w-none min-[1000px]:overflow-y-auto border-r border-primary bg-background flex flex-col z-40 -translate-x-full min-[1000px]:translate-x-0 transition-transform duration-300 ease-in-out"
>
  <button
    id="close-left-panel"
    class="absolute top-4 right-4 min-[1000px]:hidden font-mono text-xs uppercase tracking-widest text-muted hover:text-text transition-colors"
    aria-label="Close navigation menu"
  >
    × Close
  </button>
  <!-- Brand header -->
  <div class="border-b border-primary grid grid-cols-2">
    <!-- Title: full-width row 1 by default; col 2 / row 1 at 1300px+ -->
    <div class="col-start-1 col-span-2 row-start-1 p-6 self-start border-primary min-[1000px]:border-b min-[1000px]:min-h-37">
      <h1 class="font-display italic text-[40px] leading-12.5 text-text">
        Jordan A.F.
      </h1>
      <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted">
        Shopify & JS/TS Development
      </p>
      <AvailabilityBadge class="mt-3" />
    </div>
    <!-- Image: col 1, row 2, portrait by default; col 1, row-span-2 at 1300px+ -->
    <div class="hidden min-[1000px]:block col-start-1 row-start-2 row-span-1 aspect-2/3 border-r border-primary">
      <Picture
        src={profilePic}
        formats={['avif', 'webp']}
        alt="Jordan A.F."
        width={250}
        densities={[1, 2]}
        sizes="250px"
        class="w-full h-full object-cover object-top grayscale-hover"
      />
    </div>
    <!-- About: col 2, row 2 always -->
    <div class="hidden min-[1000px]:flex col-start-2 row-start-2 p-5 pr-3.5 flex-col justify-center">
      <!-- <p class="text-base min-[1000px]:text-base/8 text-muted leading-snug ">
        Full-stack developer specialising in Shopify commerce and JS/TS engineering. I build fast, precise digital storefronts for brands that care about craft — from custom theme development to bespoke Storefront API integrations.
      </p> -->
      <p class="text-base min-[1000px]:text-[1rem] text-text leading-8 indent-3">
        I am a Shopify / JavaScript developer with over 5 years of experience building eCommerce storefronts for everyone from boutique shops to enterprise brands serving 1M+ monthly visitors, with a consistent focus on CRO-driven feature work, improving Core Web Vitals, and quality user experience.
      </p>
    </div>
  </div>

  <!-- 2×2 bento navigation grid -->
  <div class="grid grid-cols-1 grid-rows-4 flex-1 min-[1000px]:grid-cols-2 min-[1000px]:grid-rows-2">
    {navCells.map((cell) => {
      const Tag = cell.tag;
      return (
        <Tag
          class:list={[
            'nav-cell relative flex flex-col justify-between p-5',
            cell.base,
            cell.active && 'bg-surface-container-high',
          ]}
          {...cell.attrs}
        >
          <div class="marquee-wrap" aria-hidden="true">
            <div class="marquee-track">
              {Array.from({ length: 4 }).map(() => (
                <span class="marquee-text">{cell.title}</span>
              ))}
            </div>
          </div>
          <span class="nav-cell-label font-mono text-sm uppercase tracking-[0.1em] text-muted relative z-10">{cell.label}</span>
          <span class="nav-cell-title font-display text-3xl text-text relative z-10">{cell.title}</span>
        </Tag>
      );
    })}
  </div>

  <!-- Tech tags -->
  <div class="p-8 border-t border-primary">
    <div class="flex flex-wrap gap-2">
      {TECH_TAGS.map((tag) => <TechBadge tag={tag} variant="panel" />)}
    </div>
  </div>

</aside>

<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .nav-cell {
    position: relative;
    transition: background-color 400ms ease;
  }

  .nav-cell:hover,
  .nav-cell:focus-visible {
    /* background-color: color-mix(in oklab, var(--color-accent-taupe) 30%, transparent); */
    /* background-color: #c8b6a66e; */
    background-color: var(--color-accent-taupe-dark);
  }

  .marquee-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 400ms ease;
  }

  .nav-cell:hover .marquee-wrap,
  .nav-cell:focus-visible .marquee-wrap {
    opacity: 1;
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    animation: marquee-scroll 9s linear infinite;
  }

  .marquee-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 96px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.07);
    padding-right: 48px;
    user-select: none;
  }

  .nav-cell-label {
    transition: color 400ms ease;
  }

  .nav-cell:hover .nav-cell-label,
  .nav-cell:focus-visible .nav-cell-label {
    color: var(--color-hover-muted);
  }

  .nav-cell-title {
    transition: color 400ms ease;
  }

  .nav-cell:hover .nav-cell-title,
  .nav-cell:focus-visible .nav-cell-title {
    color: var(--color-hover-text);
  }
</style>
