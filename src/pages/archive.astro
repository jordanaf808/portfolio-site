---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects.ts';
import { jobRoles } from '../data/jobRoles.ts';

const startYear = (y: string): number => parseInt(y.match(/\d{4}/)?.[0] ?? '0', 10)
const sorted = [...projects, ...jobRoles].sort((a, b) => startYear(b.year) - startYear(a.year))
---
<Layout title="Archive" activePage="archive">
  <!-- Header -->
  <div class="p-12 border-b border-primary">
    <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-2">The Index</p>
    <h2 class="font-display text-5xl italic text-text">Archive</h2>
    <p class="text-sm text-muted mt-4 max-w-md">
      A raw chronological ledger of architectural digital builds, technical experiments,
      and commercial deployments.
    </p>
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="w-full border-collapse">
      <thead>
        <tr class="border-b border-primary">
          <th class="text-left p-6 font-mono text-xs uppercase tracking-[0.1em] text-muted w-20">Year</th>
          <th class="text-left p-6 font-mono text-xs uppercase tracking-[0.1em] text-muted">Project</th>
          <th class="text-left p-6 font-mono text-xs uppercase tracking-[0.1em] text-muted hidden md:table-cell">Client</th>
          <th class="text-left p-6 font-mono text-xs uppercase tracking-[0.1em] text-muted hidden lg:table-cell">Tech</th>
          <th class="text-left p-6 font-mono text-xs uppercase tracking-[0.1em] text-muted w-24">Link</th>
        </tr>
      </thead>
      <tbody>
        {sorted.map((entry) => (
          <tr
            class="border-b border-primary hover:bg-accent-taupe/20 transition-colors duration-300 cursor-pointer"
            onclick={`window.location.href='/projects/${entry.slug}'`}
          >
            <td class="p-6 font-mono text-xs text-muted">{entry.year}</td>
            <td class="p-6">
              <p class="font-display text-lg text-text">{entry.title}</p>
              <p class="font-mono text-xs uppercase tracking-[0.1em] text-muted mt-0.5">
                {entry.category} | {entry.type === 'jobRole' ? 'ROLE' : 'PROJECT'}
              </p>
            </td>
            <td class="p-6 font-mono text-xs text-muted hidden md:table-cell">{entry.client ?? '—'}</td>
            <td class="p-6 hidden lg:table-cell">
              <div class="flex flex-wrap gap-1">
                {entry.tech.slice(0, 3).map((t) => (
                  <span class="font-mono text-xs uppercase tracking-[0.05em] text-muted border border-muted/40 px-1.5 py-0.5">
                    {t}
                  </span>
                ))}
              </div>
            </td>
            <td class="p-6">
              <a
                href={`/projects/${entry.slug}`}
                class="font-mono text-xs uppercase tracking-[0.1em] text-text hover:text-muted transition-colors"
              >
                View →
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <footer class="p-12 border-t border-primary">
    <p class="font-mono text-xs text-muted">© {new Date().getFullYear()} The Commerce Boutique</p>
  </footer>
</Layout>
